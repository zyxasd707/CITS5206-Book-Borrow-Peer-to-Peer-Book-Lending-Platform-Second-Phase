FROM node:20

WORKDIR /app

ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_WS_URL
ARG NEXT_PUBLIC_STRIPE_PK
ARG NEXT_PUBLIC_STRIPE_TEST_DESTINATION_ACCOUNT_ID

ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_WS_URL=$NEXT_PUBLIC_WS_URL
ENV NEXT_PUBLIC_STRIPE_PK=$NEXT_PUBLIC_STRIPE_PK
ENV NEXT_PUBLIC_STRIPE_TEST_DESTINATION_ACCOUNT_ID=$NEXT_PUBLIC_STRIPE_TEST_DESTINATION_ACCOUNT_ID

COPY package*.json ./
RUN npm install

# extra packages
RUN npm install zustand lucide-react tailwindcss postcss autoprefixer

COPY . .

RUN npm run build

EXPOSE 3000
CMD ["npm", "run", "start"]

