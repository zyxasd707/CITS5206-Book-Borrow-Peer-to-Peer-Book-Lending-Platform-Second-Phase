DB_USER=<database-user>
DB_PASSWORD=<database-password>
DB_HOST=db
DB_PORT=3306
DB_NAME=BookBorrow

SECRET_KEY=<random-secret-key>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email configuration
BREVO_API_KEY=<brevo-api-key>
BREVO_KEY_TYPE=api-key
BREVO_SENDER_EMAIL=<verified-sender-email>
BREVO_SENDER_NAME=BookBorrow

# Stripe configuration
STRIPE_SECRET_KEY=<stripe-secret-key>
NEXT_PUBLIC_STRIPE_PK=<stripe-publishable-key>
STRIPE_WEBHOOK_SECRET=<stripe-webhook-secret>

# Public app URLs
# Local development: use localhost values.
# VPS / production: use https://www.bookborrow.org
APP_BASE_URL=http://localhost
FRONTEND_URL=http://localhost
NEXT_PUBLIC_API_URL=http://localhost
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Optional Stripe test destination account for local checkout testing
NEXT_PUBLIC_STRIPE_TEST_DESTINATION_ACCOUNT_ID=<stripe-connected-account-id>

# Shipping integration
AUSPOST_CALCULATE_API_KEY=<auspost-api-key>

# Local development origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost,http://127.0.0.1
